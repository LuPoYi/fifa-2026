# 複製這個檔為 .env 並填入你的 token(.env 已被 gitignore,不會外洩)
# football-data.org 免費 token:https://www.football-data.org/client/register
FOOTBALL_DATA_TOKEN=

# 選用:SX Bet API key(sx.bet 帳號內產生),只有 live_ws.py 的 WebSocket 即時推送需要
SX_API_KEY=

# 選用:API-Football 免費 key(https://www.api-football.com/) 100 req/日,watch_ev.py 盤中數據用
APISPORTS_KEY=
